# Example: http://127.0.0.1:5000
# Optional public chat URL. If omitted, the app can ask for it on start.
# NEXT_PUBLIC_CHAT_API_BASE=
# Optional flag for hiding the input when CHAT_API_BASE is configured only on the server.
# NEXT_PUBLIC_HAS_CHAT_API_BASE=true
NEXT_PUBLIC_MAX_INTERACTIONS=5
NEXT_PUBLIC_USE_EVAL_MOCKS=true

# Server-side chat proxy config
# CHAT_API_BASE=http://127.0.0.1:5000

# Server-side evaluation config
GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SHEETS_SPREADSHEET_NAME=
# GOOGLE_SERVICE_ACCOUNT_FILE=
# GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
